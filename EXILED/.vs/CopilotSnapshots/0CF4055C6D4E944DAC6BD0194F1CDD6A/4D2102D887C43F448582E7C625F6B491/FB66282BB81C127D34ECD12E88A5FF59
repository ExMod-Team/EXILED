using System;
using Exiled.API.Features;
using Exiled.API.Features.Doors;
using Exiled.API.Enums;
// Note: avoid ambiguous Plugin<> by using Exiled's Plugin<T> explicitly in the base class.

namespace DoorTest
{
    public class DoorTestPlugin : Exiled.API.Features.Plugin<Config>
    {
        public static DoorTestPlugin Instance { get; private set; }

        public override string Name => "DoorTest";

        public override void OnEnabled()
        {
            Instance = this;

            // Example subscriptions
            Door.DoorTriggered += OnDoorTriggered;
            Door.DoorPassed += OnDoorPassed;

            base.OnEnabled();
        }

        public override void OnDisabled()
        {
            Door.DoorTriggered -= OnDoorTriggered;
            Door.DoorPassed -= OnDoorPassed;

            base.OnDisabled();
        }

        // Door screen events removed; no handler.

        private void OnDoorTriggered(Door door, Door.DoorTrigger trigger)
        {
            if (door is null)
                return;

            // Log the trigger. If you wish to know the interacting player, integrate with
            // whichever event handler tracks recent interactors and call it here.
            Log.Info($"DoorTriggered: {door.Name} -> {trigger}");
        }

        private void OnDoorPassed(Door door, Door.DoorPass pass)
        {
            if (door is null)
                return;

            // Simple logging of a pass event; integrate player lookup if desired.
            Log.Info($"DoorPassed: {door.Name} -> {pass}");
        }
    }
}