using System;
using Exiled.API.Features;
using Exiled.API.Features.Doors;
using MEC;
using Exiled.API.Enums;
// Note: avoid ambiguous Plugin<> by using Exiled's Plugin<T> explicitly in the base class.

namespace DoorTest
{
    public class DoorTestPlugin : Exiled.API.Features.Plugin<Config>
    {
        public static DoorTestPlugin Instance { get; private set; }

        public override string Name => "DoorTest";

        public override void OnEnabled()
        {
            Instance = this;

            // Example subscriptions
            Door.DoorTriggered += OnDoorTriggered;
            Door.DoorPassed += OnDoorPassed;

            // Optionally run an automatic test sequence to exercise door events.
            if (Config.EnableAutoTest)
                StartAutoTest();

            base.OnEnabled();
        }

        public override void OnDisabled()
        {
            Door.DoorTriggered -= OnDoorTriggered;
            Door.DoorPassed -= OnDoorPassed;

            base.OnDisabled();
        }

        // Door screen events removed; no handler.

        private void OnDoorTriggered(Door door, Door.DoorTrigger trigger)
        {
            if (door is null)
                return;

            // Log the trigger. If you wish to know the interacting player, integrate with
            // whichever event handler tracks recent interactors and call it here.
            Log.Info($"DoorTriggered: {door.Name} -> {trigger}");
        }

        private void OnDoorPassed(Door door, Door.DoorPass pass)
        {
            if (door is null)
                return;

            // Simple logging of a pass event; integrate player lookup if desired.
            Log.Info($"DoorPassed: {door.Name} -> {pass}");
        }

        // Runs a simple sequence of actions against a door to trigger events for testing.
        private void StartAutoTest()
        {
            try
            {
                Door target = string.IsNullOrEmpty(Config.TestDoorName) ? Door.Random() : Door.Get(Config.TestDoorName) ?? Door.Random();
                if (target is null)
                {
                    Log.Warn("DoorTest: No door found to run auto-test on.");
                    return;
                }

                Log.Info($"DoorTest: Starting auto-test on door '{target.Name}' (id={target.InstanceId}).");

                // Open after 1s
                Timing.CallDelayed(1f, () => target.IsOpen = true);
                // Close after 3s
                Timing.CallDelayed(3f, () => target.IsOpen = false);
                // Lock after 5s
                Timing.CallDelayed(5f, () => target.Lock(DoorLockType.Regular079));
                // Unlock after 7s
                Timing.CallDelayed(7f, () => target.Unlock());
                // Simulate passing through after 9s
                Timing.CallDelayed(9f, () => target.RaisePass(Door.DoorPass.Front));
                // Simulate access granted/denied events (these call the wrapper's RaiseTrigger)
                Timing.CallDelayed(11f, () => target.RaiseTrigger(Door.DoorTrigger.AccessGranted));
                Timing.CallDelayed(13f, () => target.RaiseTrigger(Door.DoorTrigger.AccessDenied));
            }
            catch (Exception ex)
            {
                Log.Error($"DoorTest: auto-test failed: {ex}");
            }
        }
    }
}